# ============================================================
# Blog Automation — 환경 변수 템플릿
# 이 파일을 복사해 .env로 저장 후 값을 채운다.
# .env는 절대 git에 커밋하지 않는다.
# ============================================================

# ── DB ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://blog_user:changeme@localhost:5432/blog_automation

# ── LLM (Ollama) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b
OLLAMA_TEMPERATURE=0.3
OLLAMA_MAX_TOKENS=2048
OLLAMA_TIMEOUT_SEC=120
OLLAMA_MAX_RETRIES=3

# ── LLM 상용 (옵션, Phase 4) ──────────────────────────────────
USE_COMMERCIAL_LLM=0
# OPENAI_API_KEY=sk-...

# ── 자동 게시 게이트 ──────────────────────────────────────────
AUTO_PUBLISH_THRESHOLD=0.75
AUTO_PUBLISH_DISABLED=0

# ── Tistory (Phase 4, 옵션) ───────────────────────────────────
TISTORY_ENABLED=0
# TISTORY_ACCESS_TOKEN=...
# TISTORY_BLOG_NAME=your-blog

# ── Notion ───────────────────────────────────────────────────
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=...

# ── 수집 설정 ─────────────────────────────────────────────────
FETCH_TIMEOUT_SEC=30
FETCH_MAX_RETRIES=3
FETCH_RATE_LIMIT_PER_HOUR=60
FETCH_USER_AGENT=blog-automation-bot/0.1

# ── 로컬 스토리지 ─────────────────────────────────────────────
DATA_DIR=./data
LOGS_DIR=./logs

# ── Phase 4 feature flags ─────────────────────────────────────
PGVECTOR_ENABLED=0
S3_MIRROR_ENABLED=0
LITELLM_ENABLED=0
